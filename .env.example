# Copia este archivo a .env.local y rellena los valores.
# .env.local no se sube al repo.

# URL pública del sitio (para metadatos/canonical)
NEXT_PUBLIC_SITE_URL=https://mariocavaavila.vercel.app

# --- Formulario de contacto ---

# Resend: clave de API (https://resend.com)
RESEND_API_KEY=
# Dirección donde recibes los mensajes
CONTACT_TO_EMAIL=mariocavaavila@gmail.com
# Remitente verificado en Resend (un dominio o el sandbox onboarding@resend.dev)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Upstash Redis: rate limit del formulario (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
